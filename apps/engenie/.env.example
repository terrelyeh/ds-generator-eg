# Supabase（與 SpecHub 共用同一專案）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 對外 API key 加密 / BYOK 解密 — 必須與 SpecHub prod 同一把（DB 內已有用它加密的資料）
API_KEY_ENC_SECRET=

# Workspace/widget session token 簽章 key（engenie 自洽即可；換值 = 全部 token 重發）
WORKSPACE_TOKEN_SECRET=

# /demo/ask 的 passcode
DEMO_ACCESS_KEY=

# Cron 與跨 app 觸發（spechub sync → /api/cron/reindex-products）；兩個專案要同值
CRON_SECRET=

# google_doc ingest 用 service account
GOOGLE_SERVICE_ACCOUNT_JSON=

# Web ingest（可選：未設 Firecrawl 則退 Jina Reader）
FIRECRAWL_API_KEY=
JINA_API_KEY=

# LLM keys 可放 env，也可在 /settings/api-keys 頁設定（存 app_settings）
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=
